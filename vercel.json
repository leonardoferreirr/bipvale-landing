{
  "framework": null,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(fonts|renders|img|logo|fotos)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/js/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
